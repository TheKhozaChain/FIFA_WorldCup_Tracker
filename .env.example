# Copy this file to `.env` and fill in your key(s). `.env` is gitignored.
#
# Primary provider: football-data.org
#   Get a free key at https://www.football-data.org/client/register
#   Free tier: 10 requests / minute.
FOOTBALL_DATA_API_KEY=your_football_data_org_key_here

# Optional alternative provider: API-Football (api-sports.io)
#   Get a free key at https://www.api-football.com/  (100 requests / day)
API_FOOTBALL_KEY=

# Which provider to use by default: football-data | thesportsdb | offline
# (can be overridden per-run with --provider). `offline` uses the bundled
# snapshot and needs no key or network.
WCTRACKER_PROVIDER=football-data
